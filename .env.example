# Copy to .env and fill in. Only DEEPSEEK_API_KEY is required for online runs.
# Embedding + rerank run locally (sentence-transformers), so they need no key.

# --- Generation (required): DeepSeek, OpenAI-compatible API ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Optional: cloud embedding backend (only if you switch embeddings.backend=openai) ---
OPENAI_API_KEY=

# --- Optional: keep HuggingFace dataset + model cache inside the project ---
# HF_HOME=./data/raw
